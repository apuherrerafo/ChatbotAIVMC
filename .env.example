# VMC-Bot — copiar a .env y rellenar valores
# No subir .env a git

# Firecrawl (Centro de Ayuda + inventario)
FIRECRAWL_API_KEY=

# Pinecone (vector DB para RAG)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=vmc-bot-rag

# Claude (router + respuestas)
ANTHROPIC_API_KEY=

# WhatsApp / servidor
PORT=8000
# DEBUG_MODE=true   # solo local: activa campo debug en POST /api/ask (interfaz debug)
# WEBHOOK_VERIFY_TOKEN=  # para Meta Cloud API

# Opcional: STT/TTS, inventario
# GOOGLE_API_KEY=   # Gemini 2.5 Flash STT
# ELEVENLABS_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
AUTO_MAINTENANCE=false